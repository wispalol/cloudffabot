# ─── Discord Bot ───────────────────────────────────────────────
TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here
LANGUAGE=en

# ─── Ticket System ─────────────────────────────────────────────
TICKET_CATEGORY_ID=
TICKET_STAFF_ROLE_ID=
TICKET_LOG_CHANNEL_ID=
TICKET_PANEL_CHANNEL_ID=

# ─── Moderation ────────────────────────────────────────────────
MOD_LOG_CHANNEL_ID=
MUTE_ROLE_ID=

# ─── Logging ───────────────────────────────────────────────────
MESSAGE_LOG_CHANNEL_ID=
MEMBER_LOG_CHANNEL_ID=
VOICE_LOG_CHANNEL_ID=
CHANNEL_LOG_CHANNEL_ID=

# ─── Welcome System ────────────────────────────────────────────
WELCOME_CHANNEL_ID=
LEAVE_CHANNEL_ID=
AUTO_ROLE_ID=
VERIFIED_ROLE_ID=
VERIFICATION_ENABLED=false

# ─── Suggestions ───────────────────────────────────────────────
SUGGESTION_CHANNEL_ID=
SUGGESTION_STAFF_ROLE_ID=

# ─── Polls ─────────────────────────────────────────────────────
POLL_CHANNEL_ID=

# ─── Giveaways ─────────────────────────────────────────────────
GIVEAWAY_STAFF_ROLE_ID=

# ─── Auto Moderation ───────────────────────────────────────────
ANTI_SPAM_ENABLED=true
ANTI_SPAM_MAX_MESSAGES=5
ANTI_SPAM_INTERVAL_MS=5000
ANTI_SCAM_ENABLED=true
ANTI_MASS_MENTION_ENABLED=true
ANTI_MASS_MENTION_LIMIT=5
BAD_WORD_FILTER_ENABLED=true
ANTI_INVITE_ENABLED=true
ANTI_RAID_ENABLED=true
ANTI_RAID_JOIN_THRESHOLD=10
ANTI_RAID_TIME_WINDOW_MS=10000

# ─── Embed Configuration ──────────────────────────────────────
EMBED_COLOR_PRIMARY=#5865F2
EMBED_COLOR_SUCCESS=#57F287
EMBED_COLOR_ERROR=#ED4245
EMBED_COLOR_WARNING=#FEE75C
EMBED_FOOTER_TEXT=CloudFFA Bot
EMBED_FOOTER_ICON=

# ─── Database ──────────────────────────────────────────────────
DATABASE_PATH=./database.sqlite

# ─── AI / Claude Configuration ────────────────────────────────
# AI_PROVIDER should be 'claude' to use Anthropic's Claude.
# Claude provides the best answers for the /ask command, /search, and auto-answers.
# Get a Claude API key at https://console.anthropic.com/
AI_PROVIDER=claude
AI_API_KEY=
AI_MODEL=claude-3-5-sonnet-20241022

# ─── Web Search (Tavily) ──────────────────────────────────────
# Highly Recommended: Get a free API key at https://tavily.com/
# Used by /ask, /search, and auto-answer features to fetch current web results.
TAVILY_API_KEY=

